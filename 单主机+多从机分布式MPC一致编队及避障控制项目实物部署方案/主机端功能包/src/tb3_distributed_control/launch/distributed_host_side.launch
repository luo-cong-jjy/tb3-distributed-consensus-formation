<launch>
  <!-- ============================================== -->
  <!-- 分布式控制 - 主机端 Launch 文件 -->
  <!-- 功能：运行虚拟领导者、可视化节点（在台式机上运行） -->
  <!-- ============================================== -->

  <!-- ============================================== -->
  <!-- 1. 全局参数配置 -->
  <!-- ============================================== -->
  <!-- 实物实验使用系统时间（不使用仿真时间） -->
  <param name="/use_sim_time" value="false" />
  <!-- 日志级别配置 -->
  <param name="/rosconsole/log_level" value="INFO" />

  <!-- 机器人模型参数 -->
  <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="model type [burger, waffle, waffle_pi]"/>
  
  <!-- 实物参数修改点1 -->
  <!-- 系统总运行时间参数（可通过launch参数配置） -->
  <arg name="total_time" default="68" doc="real_experiment_trajectory_line(实物轨迹_直线)-32s ; real_experiment_trajectory(实物轨迹_S形)-68s ; real_circle_s_trajectory(实物轨迹_圆形-S中)-32s" />
  
  <!-- 实物参数修改点2 -->
  <!-- 轨迹类型参数（可通过launch参数配置） -->
  <arg name="trajectory_type" default="real_experiment_trajectory" doc="Trajectory type: Trajectory type: real_experiment_trajectory_line(实物轨迹_直线),real_circle_s_trajectory(实物轨迹_圆形-S中)," />
  
  <!-- 实物机器人控制参数（主机端启用） -->
  <arg name="enable_real_robot" default="false" doc="Enable real robot control"/>
  <arg name="real_robot_name" default="tb3_real" doc="Real robot name for cmd_vel topic"/>
  
  <!-- RViz可视化参数 -->
  <arg name="open_rviz" default="false" doc="Open RViz for visualization"/>
  
  <!-- 虚拟领导者命名空间参数 -->
  <arg name="virtual_leader_ns" default="tb3_virtual_leader" doc="Virtual leader namespace"/>

  <!-- 机器人命名空间参数（支持多机器人） -->
  <arg name="first_tb3"  default="tb3_0"/>
  <arg name="second_tb3" default="tb3_1"/>
  <arg name="third_tb3"  default="tb3_2"/>
  <arg name="forth_tb3"  default="tb3_3"/>
  <arg name="fifth_tb3"  default="tb3_4"/>

  <!-- 全局坐标系变换：将odom连接到world坐标系 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="world_to_odom_global"
        args="0 0 0 0 0 0 world odom" />

  <!-- ============================================== -->
  <!-- 2. 真实机器人模型和TF发布（RViz可视化必需） -->
  <!-- ============================================== -->
  <!-- 机器人1: tb3_0 -->
  <group ns="$(arg first_tb3)">
    <param name="robot_description" command="$(find xacro)/xacro --inorder $(find tb3_distributed_control)/urdf/turtlebot3_$(arg model).urdf.xacro" />
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
      <param name="publish_frequency" type="double" value="50.0" />
      <param name="tf_prefix" value="$(arg first_tb3)" />
    </node>
    <!-- 连接到全局坐标系 -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="$(arg first_tb3)_world_to_odom"
          args="0 0 0 0 0 0 world $(arg first_tb3)/odom" />
  </group>

  <!-- 机器人2: tb3_1 -->
  <group ns="$(arg second_tb3)">
    <param name="robot_description" command="$(find xacro)/xacro --inorder $(find tb3_distributed_control)/urdf/turtlebot3_$(arg model).urdf.xacro" />
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
      <param name="publish_frequency" type="double" value="50.0" />
      <param name="tf_prefix" value="$(arg second_tb3)" />
    </node>
    <node pkg="tf2_ros" type="static_transform_publisher" name="$(arg second_tb3)_world_to_odom"
          args="0 0 0 0 0 0 world $(arg second_tb3)/odom" />
  </group>

  <!-- 机器人3: tb3_2 -->
  <group ns="$(arg third_tb3)">
    <param name="robot_description" command="$(find xacro)/xacro --inorder $(find tb3_distributed_control)/urdf/turtlebot3_$(arg model).urdf.xacro" />
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
      <param name="publish_frequency" type="double" value="50.0" />
      <param name="tf_prefix" value="$(arg third_tb3)" />
    </node>
    <node pkg="tf2_ros" type="static_transform_publisher" name="$(arg third_tb3)_world_to_odom"
          args="0 0 0 0 0 0 world $(arg third_tb3)/odom" />
  </group>

  <!-- 机器人4: tb3_3 -->
  <group ns="$(arg forth_tb3)">
    <param name="robot_description" command="$(find xacro)/xacro --inorder $(find tb3_distributed_control)/urdf/turtlebot3_$(arg model).urdf.xacro" />
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
      <param name="publish_frequency" type="double" value="50.0" />
      <param name="tf_prefix" value="$(arg forth_tb3)" />
    </node>
    <node pkg="tf2_ros" type="static_transform_publisher" name="$(arg forth_tb3)_world_to_odom"
          args="0 0 0 0 0 0 world $(arg forth_tb3)/odom" />
  </group>

  <!-- 机器人5: tb3_4 -->
  <group ns="$(arg fifth_tb3)">
    <param name="robot_description" command="$(find xacro)/xacro --inorder $(find tb3_distributed_control)/urdf/turtlebot3_$(arg model).urdf.xacro" />
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
      <param name="publish_frequency" type="double" value="50.0" />
      <param name="tf_prefix" value="$(arg fifth_tb3)" />
    </node>
    <node pkg="tf2_ros" type="static_transform_publisher" name="$(arg fifth_tb3)_world_to_odom"
          args="0 0 0 0 0 0 world $(arg fifth_tb3)/odom" />
  </group>

  <!-- ============================================== -->
  <!-- 3. 虚拟领导者机器人模型（仅用于RViz可视化） -->
  <!-- ============================================== -->
  <group ns="$(arg virtual_leader_ns)">
    <param name="robot_description" command="$(find xacro)/xacro --inorder $(find tb3_distributed_control)/urdf/turtlebot3_$(arg model).urdf.xacro" />
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
      <param name="publish_frequency" type="double" value="50.0" />
      <param name="tf_prefix" value="$(arg virtual_leader_ns)" />
    </node>

    <!-- 虚拟领导者TF变换（仅发布world到odom的静态变换，动态变换由leader_node.py发布） -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="$(arg virtual_leader_ns)_world_to_odom"
          args="0 0 0 0 0 0 world $(arg virtual_leader_ns)/odom" output="screen">
    </node>

    <!-- 虚拟领导者轮子静态变换（因为虚拟领导者不需要动态轮子转动） -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="$(arg virtual_leader_ns)_wheel_left"
          args="0.0 0.08 0.023 -1.57 0 0 $(arg virtual_leader_ns)/base_link $(arg virtual_leader_ns)/wheel_left_link" />
    <node pkg="tf2_ros" type="static_transform_publisher" name="$(arg virtual_leader_ns)_wheel_right"
          args="0.0 -0.08 0.023 -1.57 0 0 $(arg virtual_leader_ns)/base_link $(arg virtual_leader_ns)/wheel_right_link" />
  </group>

  <!-- ============================================== -->
  <!-- 4. 可视化节点（延迟0.95秒启动） -->
  <!-- ============================================== -->
  <node name="result_visualizer" 
        pkg="tb3_distributed_control" 
        type="visualize_results.py" 
        output="screen"
        launch-prefix="bash -c 'sleep 0.90; $0 $@'">
  </node>

  <!-- ============================================== -->
  <!-- 5. 虚拟领导者节点（延迟1秒启动） -->
  <!-- ============================================== -->
  <!-- 实物修改点3：领导者初始位置：直线：（-0.15，0.15，0.0） S形：（0.0，0.0，0.0） -->
  <node name="leader_node" 
        pkg="tb3_distributed_control" 
        type="leader_node.py" 
        output="screen"
        launch-prefix="bash -c 'sleep 1.0; $0 $@'"
        ns="$(arg virtual_leader_ns)">
    <param name="total_time" value="$(arg total_time)"/> <!-- 传递总时间参数 -->
    <param name="trajectory_type" value="$(arg trajectory_type)"/> <!-- 传递轨迹类型参数 -->
    <param name="enable_real_robot" value="$(arg enable_real_robot)"/> <!-- 启用真实机器人控制 -->
    <param name="real_robot_name" value="$(arg real_robot_name)"/> <!-- 真实机器人名称 -->
    <param name="virtual_leader_ns" value="$(arg virtual_leader_ns)"/> <!-- 虚拟领导者命名空间 -->
    <param name="~leader_init_x" value="0.0"/> <!-- 领导者初始x -->
    <param name="~leader_init_y" value="0.0"/> <!-- 领导者初始y -->
    <param name="~leader_init_yaw" value="0.0"/> <!-- 领导者初始yaw -->
  </node>

  <!-- 6. 分布式控制可视化节点 -->
  <node name="distributed_control_visualizer" 
        pkg="tb3_distributed_control" 
        type="distributed_control_visualizer.py" 
        output="screen"
        launch-prefix="bash -c 'sleep 1.5; $0 $@'">
  </node>

  <!-- ============================================== -->
  <!-- 7. RViz 可视化（延迟2秒启动） -->
  <!-- ============================================== -->
  <group if="$(arg open_rviz)">
    <node name="rviz" 
          pkg="rviz" 
          type="rviz" 
          args="-d $(find tb3_distributed_control)/rviz/tb3_distributed_control.rviz"
          launch-prefix="bash -c 'sleep 2.0; $0 $@'"
          output="screen" />
  </group>

  <!-- ============================================== -->
  <!-- 8. 运行状态提示 -->
  <!-- ============================================== -->
  <node name="launch_notification1" 
        pkg="tb3_distributed_control"  
        type="print_notification.py"   
        output="screen">
      <param name="~text" value="==============================================" />
  </node>

  <node name="launch_notification2" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="主机端节点启动成功！(Host Side)" />
  </node>

  <node name="launch_notification3" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="1. 已为5个机器人加载RViz显示模型（tb3_0~tb3_4）" />
  </node>

  <node name="launch_notification4" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="2. 虚拟领导者节点已启动" />
  </node>

  <node name="launch_notification5" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="3. 轨迹类型: $(arg trajectory_type)" />
  </node>

  <node name="launch_notification6" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="4. 程序运行 $(arg total_time) 秒后自动停止" />
  </node>

  <node name="launch_notification7" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="5. 请确保各机器人端已通过以下命令启动:" />
  </node>

  <node name="launch_notification8" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="   ROS_NAMESPACE=tb3_X roslaunch turtlebot3_bringup turtlebot3_robot.launch multi_robot_name:=tb3_X" />
  </node>

  <node name="launch_notification9" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="   roslaunch tb3_distributed_control distributed_robot_side.launch robot_id:=X" />
  </node>

  <node name="launch_notification10" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="==============================================" />
  </node>

</launch>
