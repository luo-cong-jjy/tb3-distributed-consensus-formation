<launch>
  <!-- ============================================== -->
  <!-- 分布式控制 - 机器人端 Launch 文件 -->
  <!-- 功能：在TurtleBot3实物机器人上运行分布式控制节点 -->
  <!-- 前提：机器人底盘已通过以下命令启动 -->
  <!--       ROS_NAMESPACE=tb3_0 roslaunch turtlebot3_bringup turtlebot3_robot.launch multi_robot_name:=tb3_0 -->
  <!-- 部署：将此文件复制到机器人的工作空间并运行 -->
  <!-- ============================================== -->

  <!-- ============================================== -->
  <!-- 1. 全局参数配置 -->
  <!-- ============================================== -->
  <!-- 实物实验使用系统时间（不使用仿真时间） -->
  <param name="/use_sim_time" value="false" />
  <!-- 日志级别配置 -->
  <param name="/rosconsole/log_level" value="INFO" />
  <!-- LiDAR类型参数 -->
  <arg name="lidar_type" default="LDS-02" doc="LiDAR type: LDS-01 or LDS-02"/>
  <!-- 机器人ID参数（必须设置，对应tb3_0, tb3_1, ...） -->
  <arg name="robot_id" default="0" doc="Robot ID (0-4)"/>

  <!-- ============================================== -->
  <!-- 2. 分布式控制节点 -->
  <!-- ============================================== -->
  <node name="tb3_controller_$(arg robot_id)" 
        pkg="tb3_distributed_control" 
        type="tb3_controller_node_real.py" 
        output="screen">
    <param name="lidar_type" value="$(arg lidar_type)"/>
    <param name="robot_id" value="$(arg robot_id)"/>
  </node>

  <!-- ============================================== -->
  <!-- 3. 运行状态提示 -->
  <!-- ============================================== -->
  <node name="launch_notification1" 
        pkg="tb3_distributed_control"  
        type="print_notification.py"   
        output="screen">
      <param name="~text" value="==============================================" />
  </node>

  <node name="launch_notification2" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="机器人端节点启动成功！(Robot Side)" />
  </node>

  <node name="launch_notification3" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="1. 机器人ID: $(arg robot_id)" />
  </node>

  <node name="launch_notification4" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="2. 请确保已通过以下命令启动机器人底盘:" />
  </node>

  <node name="launch_notification5" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="   ROS_NAMESPACE=tb3_$(arg robot_id) roslaunch turtlebot3_bringup turtlebot3_robot.launch multi_robot_name:=tb3_$(arg robot_id)" />
  </node>

  <node name="launch_notification6" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="3. 请确保主机端已启动 distributed_host_side.launch" />
  </node>

  <node name="launch_notification7" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="4. 请确保已配置ROS_MASTER_URI和ROS_HOSTNAME" />
  </node>

  <node name="launch_notification8" 
        pkg="tb3_distributed_control" 
        type="print_notification.py" 
        output="screen">
      <param name="~text" value="==============================================" />
  </node>

</launch>
